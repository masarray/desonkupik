{
  "name": "desonkupik",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "cf:deploy": "npm run build && npx wrangler@latest pages deploy dist --project-name desonkupik",
    "cf:preview": "npm run build && npx wrangler@latest pages dev dist --project-name desonkupik",
    "dev:desktop": "vite --host 127.0.0.1",
    "desktop:dev": "concurrently -k \"npm run dev:desktop\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:build": "npm run build && electron-builder",
    "desktop:win": "npm run build && electron-builder --win nsis portable",
    "desktop:mac": "npm run build && electron-builder --mac dmg pkg",
    "desktop:linux": "npm run build && electron-builder --linux AppImage deb tar.gz",
    "desktop:release": "npm run build && electron-builder --win nsis portable --mac dmg pkg --linux AppImage deb tar.gz",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@tailwindcss/vite": "^4.2.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.3.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "4.6.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^15.15.0",
    "prettier": "^3.9.6",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "8.1.5",
    "concurrently": "^9.2.0",
    "electron": "^37.2.0",
    "electron-builder": "26.15.3",
    "wait-on": "^8.0.3"
  },
  "version": "0.3.83",
  "description": "Beautiful one-click audio mastering for web and desktop by SonKuPik.",
  "keywords": [
    "audio",
    "mastering",
    "desktop",
    "electron",
    "react",
    "creator-tools"
  ],
  "productName": "DeSonKuPik",
  "author": "SonKuPik",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.sonkupik.desonkupik",
    "productName": "DeSonKuPik",
    "copyright": "Copyright © 2026 SonKuPik",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DeSonKuPik",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "pkg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "pkg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "linux": {
      "icon": "build/icon.png",
      "category": "Audio;AudioVideo;Music",
      "maintainer": "SonKuPik",
      "synopsis": "AI-inspired audio mastering desktop app",
      "description": "DeSonKuPik is a desktop and web audio mastering app by SonKuPik.",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "license": "GPL-3.0-or-later",
  "homepage": "https://masarray.github.io/desonkupik/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masarray/desonkupik.git"
  },
  "bugs": {
    "url": "https://github.com/masarray/desonkupik/issues"
  }
}
